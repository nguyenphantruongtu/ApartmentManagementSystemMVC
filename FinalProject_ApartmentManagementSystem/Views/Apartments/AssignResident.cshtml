@model FinalProject_ApartmentManagementSystem.ViewModels.AssignResidentViewModel
@{
    ViewData["Title"] = "Gan cu dan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Gan cu dan</div>
            <div class="admin-subtitle">Gan cu dan vao can ho @Model.ApartmentCode.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Details" asp-route-id="@Model.ApartmentId" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-person-plus"></i>
                Thong tin gan cu dan
            </div>
        </div>
        <div class="card-body">
            <form asp-action="AssignResident" asp-route-id="@Model.ApartmentId" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ApartmentId" />
                <div>
                    <label class="form-label">Can ho</label>
                    <input class="form-input" value="@Model.ApartmentCode - @Model.BuildingName" disabled />
                </div>
                <div>
                    <label class="form-label">Cu dan</label>
                    <select asp-for="ResidentId" class="form-input">
                        <option value="">-- Chon cu dan --</option>
                        @foreach (var resident in Model.ResidentOptions)
                        {
                            <option value="@resident.ResidentId">
                                @resident.FullName (@resident.Phone ?? "N/A") - @resident.Email
                            </option>
                        }
                    </select>
                    <span asp-validation-for="ResidentId" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ngay vao</label>
                    <input asp-for="MoveInDate" class="form-input" type="date" />
                    <span asp-validation-for="MoveInDate" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ngay ra (neu co)</label>
                    <input asp-for="MoveOutDate" class="form-input" type="date" />
                    <span asp-validation-for="MoveOutDate" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Chu ho</label>
                    <input asp-for="IsOwner" type="checkbox" />
                </div>
                <div>
                    <label class="form-label">Ghi chu</label>
                    <input asp-for="Notes" class="form-input" />
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Gan cu dan
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.ApartmentId" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
