@model FinalProject_ApartmentManagementSystem.ViewModels.RolesIndexViewModel
@{
    ViewData["Title"] = "Quan ly vai tro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Quan ly vai tro</div>
            <div class="admin-subtitle">CRUD role va gan vai tro cho nguoi dung.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Users" class="btn-ams btn-ams-outline">
                <i class="bi bi-people"></i> Quan ly nguoi dung
            </a>
            <a asp-action="Create" class="btn-ams btn-ams-primary">
                <i class="bi bi-plus-circle"></i> Tao vai tro
            </a>
        </div>
    </div>

    @if (TempData["RoleSuccess"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        <div class="alert-ams">@message</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-shield-check"></i>
                Danh sach vai tro
            </div>
        </div>
        <div class="card-body">
            @if (Model.Roles.Count == 0)
            {
                <div class="admin-subtitle">Chua co vai tro nao. Hay tao vai tro dau tien.</div>
            }
            else
            {
                <div class="role-grid">
                    @foreach (var role in Model.Roles)
                    {
                        <div class="role-card">
                            <div class="role-name">@role.RoleName</div>
                            <div class="role-desc">@((role.Description ?? "Chua co mo ta"))</div>
                            <div class="role-footer">
                                <span class="role-count">
                                    <i class="bi bi-people-fill"></i> @role.UserCount nguoi dung
                                </span>
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn-ams btn-ams-outline">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Xoa vai tro nay?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-ams btn-ams-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
