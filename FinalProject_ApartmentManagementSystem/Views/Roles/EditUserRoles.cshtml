@model FinalProject_ApartmentManagementSystem.ViewModels.RoleAssignmentViewModel
@{
    ViewData["Title"] = "Cap nhat vai tro nguoi dung";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Cap nhat vai tro</div>
            <div class="admin-subtitle">Nguoi dung: @Model.FullName (@Model.Username)</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Users" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-shield-check"></i>
                Chon vai tro
            </div>
        </div>
        <div class="card-body">
            <form asp-action="EditUserRoles" asp-route-id="@Model.UserId" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <div>
                    <label class="form-label">Email</label>
                    <input class="form-input" value="@Model.Email" readonly />
                </div>
                <div>
                    <label class="form-label">Danh sach vai tro</label>
                    <div class="checkbox-grid">
                        @foreach (var role in Model.RoleOptions)
                        {
                            var checkedAttr = Model.SelectedRoleIds.Contains(role.RoleId);
                            <label class="checkbox-item">
                                <input type="checkbox"
                                       name="SelectedRoleIds"
                                       value="@role.RoleId"
                                       @(checkedAttr ? "checked" : string.Empty) />
                                <span>@role.RoleName</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="admin-subtitle">
                    Ghi chu: thay doi vai tro se ap dung sau khi nguoi dung dang nhap lai.
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Cap nhat
                    </button>
                    <a asp-action="Users" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>
