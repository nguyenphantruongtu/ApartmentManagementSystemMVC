@model FinalProject_ApartmentManagementSystem.ViewModels.UsersIndexViewModel
@{
    ViewData["Title"] = "Gan vai tro cho nguoi dung";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Gan vai tro cho nguoi dung</div>
            <div class="admin-subtitle">Chon nguoi dung va cap nhat role.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quan ly vai tro
            </a>
        </div>
    </div>

    @if (TempData["RoleSuccess"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        <div class="alert-ams">@message</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-people"></i>
                Danh sach nguoi dung
            </div>
        </div>
        <div class="card-body">
            @if (Model.Users.Count == 0)
            {
                <div class="admin-subtitle">Chua co nguoi dung nao.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ten</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Vai tro</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Username</td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.Roles.Length == 0)
                                    {
                                        <span class="admin-subtitle">Chua gan</span>
                                    }
                                    else
                                    {
                                        foreach (var role in user.Roles)
                                        {
                                            <span class="badge-role">@role</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditUserRoles" asp-route-id="@user.UserId" class="btn-ams btn-ams-outline">
                                        <i class="bi bi-shield-check"></i> Cap nhat
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
