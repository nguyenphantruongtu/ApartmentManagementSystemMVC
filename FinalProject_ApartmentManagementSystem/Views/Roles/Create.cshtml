@model FinalProject_ApartmentManagementSystem.ViewModels.RoleFormViewModel
@{
    ViewData["Title"] = "Tao vai tro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Tao vai tro moi</div>
            <div class="admin-subtitle">Them role moi cho he thong.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-plus-circle"></i>
                Thong tin vai tro
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Ten vai tro</label>
                    <input asp-for="RoleName" class="form-input" />
                    <span asp-validation-for="RoleName" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Mo ta</label>
                    <input asp-for="Description" class="form-input" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Luu
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
