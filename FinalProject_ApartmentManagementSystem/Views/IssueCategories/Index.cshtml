@model FinalProject_ApartmentManagementSystem.ViewModels.IssueCategoriesIndexViewModel
@{
    ViewData["Title"] = "Quan ly danh muc su co";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Quan ly danh muc su co</div>
            <div class="admin-subtitle">Danh sach va thao tac danh muc su co.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Create" class="btn-ams btn-ams-primary">
                <i class="bi bi-plus-circle"></i> Tao danh muc
            </a>
        </div>
    </div>

    @if (TempData["IssueCategorySuccess"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-ams">@success</div>
    }
    @if (TempData["IssueCategoryError"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="alert-ams">@error</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-tags"></i>
                Danh sach danh muc
            </div>
        </div>
        <div class="card-body">
            @if (Model.Categories.Count == 0)
            {
                <div class="admin-subtitle">Chua co danh muc nao. Hay tao danh muc dau tien.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ten danh muc</th>
                            <th>Mo ta</th>
                            <th>Uu tien</th>
                            <th>Thoi gian du kien</th>
                            <th>Trang thai</th>
                            <th>So su co</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model.Categories)
                        {
                            <tr>
                                <td>@category.CategoryName</td>
                                <td>@(string.IsNullOrWhiteSpace(category.Description) ? "-" : category.Description)</td>
                                <td>@category.PriorityLevel</td>
                                <td>@category.EstimatedResolutionDays ngay</td>
                                <td>@(category.IsActive ? "Dang hoat dong" : "Tam khoa")</td>
                                <td>@category.IssueCount</td>
                                <td>
                                    <div class="admin-actions">
                                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn-ams btn-ams-outline">
                                            <i class="bi bi-pencil"></i> Sua
                                        </a>
                                        <form asp-action="ToggleActive" asp-route-id="@category.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-ams btn-ams-outline">
                                                <i class="bi bi-lightning"></i> @(category.IsActive ? "Tam khoa" : "Kich hoat")
                                            </button>
                                        </form>
                                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" onsubmit="return confirm('Xoa danh muc nay?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-ams btn-ams-danger">
                                                <i class="bi bi-trash"></i> Xoa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
