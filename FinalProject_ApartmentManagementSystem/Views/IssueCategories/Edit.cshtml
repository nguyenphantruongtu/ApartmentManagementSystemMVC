@model FinalProject_ApartmentManagementSystem.ViewModels.IssueCategoryFormViewModel
@{
    ViewData["Title"] = "Cap nhat danh muc su co";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Cap nhat danh muc su co</div>
            <div class="admin-subtitle">Chinh sua thong tin danh muc su co.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-tags"></i>
                Thong tin danh muc
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div>
                    <label class="form-label">Ten danh muc</label>
                    <input asp-for="CategoryName" class="form-input" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Mo ta</label>
                    <input asp-for="Description" class="form-input" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Muc uu tien</label>
                    <input asp-for="PriorityLevel" class="form-input" />
                    <span asp-validation-for="PriorityLevel" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">So ngay du kien</label>
                    <input asp-for="EstimatedResolutionDays" class="form-input" />
                    <span asp-validation-for="EstimatedResolutionDays" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Trang thai</label>
                    <div>
                        <input asp-for="IsActive" />
                        <span>Dang hoat dong</span>
                    </div>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Luu
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
