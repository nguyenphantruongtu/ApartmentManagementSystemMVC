@model FinalProject_ApartmentManagementSystem.ViewModels.InvoiceCreateViewModel
@{
    ViewData["Title"] = "Tao hoa don";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Tao hoa don moi</div>
            <div class="admin-subtitle">Chon can ho, cu dan va danh sach phi phai thu.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-file-earmark-plus"></i>
                Thong tin hoa don
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div style="grid-column:1 / -1;">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
                <div>
                    <label class="form-label">Can ho</label>
                    <select asp-for="ApartmentId" class="form-input">
                        <option value="">-- Chon can ho --</option>
                        @foreach (var apartment in Model.ApartmentOptions)
                        {
                            <option value="@apartment.ApartmentId">@apartment.ApartmentCode</option>
                        }
                    </select>
                    <span asp-validation-for="ApartmentId" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Cu dan</label>
                    <select asp-for="ResidentId" class="form-input">
                        <option value="">-- Chon cu dan --</option>
                        @foreach (var resident in Model.ResidentOptions)
                        {
                            <option value="@resident.ResidentId">@resident.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="ResidentId" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Thang</label>
                    <input asp-for="BillingMonth" class="form-input" />
                    <span asp-validation-for="BillingMonth" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Nam</label>
                    <input asp-for="BillingYear" class="form-input" />
                    <span asp-validation-for="BillingYear" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ngay phat hanh</label>
                    <input asp-for="IssueDate" class="form-input" type="date" />
                    <span asp-validation-for="IssueDate" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Han thanh toan</label>
                    <input asp-for="DueDate" class="form-input" type="date" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>
                <div style="grid-column:1 / -1;">
                    <label class="form-label">Ghi chu</label>
                    <input asp-for="Notes" class="form-input" />
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div style="grid-column:1 / -1;">
                    <div class="card" style="margin-top:10px;">
                        <div class="card-header">
                            <div class="card-title">
                                <i class="bi bi-list-check"></i>
                                Danh sach phi ap dung
                            </div>
                        </div>
                        <div class="card-body">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Loai phi</th>
                                        <th>Don vi</th>
                                        <th>Don gia</th>
                                        <th>So luong</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.FeeItems.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input type="hidden" asp-for="FeeItems[@i].FeeTypeId" />
                                                <input type="hidden" asp-for="FeeItems[@i].FeeName" />
                                                <input type="hidden" asp-for="FeeItems[@i].Unit" />
                                                <input type="hidden" asp-for="FeeItems[@i].UnitPrice" />
                                                @Model.FeeItems[i].FeeName
                                            </td>
                                            <td>@(string.IsNullOrWhiteSpace(Model.FeeItems[i].Unit) ? "-" : Model.FeeItems[i].Unit)</td>
                                            <td>@Model.FeeItems[i].UnitPrice.ToString("#,##0")</td>
                                            <td>
                                                <input asp-for="FeeItems[@i].Quantity" class="form-input" />
                                                <span asp-validation-for="FeeItems[@i].Quantity" class="text-danger"></span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="admin-actions" style="grid-column:1 / -1;">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Luu hoa don
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
