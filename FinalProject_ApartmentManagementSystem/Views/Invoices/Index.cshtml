@model FinalProject_ApartmentManagementSystem.ViewModels.InvoiceIndexViewModel
@{
    ViewData["Title"] = "Danh sach hoa don";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canManageInvoices = User.IsInRole("Admin") || User.IsInRole("Staff");
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Danh sach hoa don</div>
            <div class="admin-subtitle">Theo doi cac hoa don theo thang va trang thai.</div>
        </div>
        @if (canManageInvoices)
        {
            <div class="admin-actions">
                <a asp-action="Create" class="btn-ams btn-ams-primary">
                    <i class="bi bi-plus-circle"></i> Tao hoa don
                </a>
            </div>
        }
    </div>

    @if (TempData["InvoiceSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-ams">@success</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-receipt"></i>
                Bo loc hoa don
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="form-grid">
                <div>
                    <label class="form-label">Trang thai</label>
                    <select name="status" class="form-input">
                        <option value="">-- Tat ca --</option>
                        @foreach (var option in Model.Filter.StatusOptions)
                        {
                            <option value="@option" selected="@(Model.Filter.Status == option ? "selected" : null)">@option</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Thang</label>
                    <input name="month" value="@(Model.Filter.Month?.ToString() ?? "")" class="form-input" />
                </div>
                <div>
                    <label class="form-label">Nam</label>
                    <input name="year" value="@(Model.Filter.Year?.ToString() ?? "")" class="form-input" />
                </div>
                @if (Model.ApartmentOptions.Count > 0)
                {
                    <div>
                        <label class="form-label">Can ho</label>
                        <select name="apartmentId" class="form-input">
                            <option value="">-- Tat ca --</option>
                            @foreach (var apartment in Model.ApartmentOptions)
                            {
                                <option value="@apartment.ApartmentId" selected="@(Model.Filter.ApartmentId == apartment.ApartmentId ? "selected" : null)">
                                    @apartment.ApartmentCode
                                </option>
                            }
                        </select>
                    </div>
                }
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-filter"></i> Loc
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Xoa loc</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card" style="margin-top:20px;">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-file-earmark-text"></i>
                Danh sach hoa don
            </div>
        </div>
        <div class="card-body">
            @if (Model.Invoices.Count == 0)
            {
                <div class="admin-subtitle">Chua co hoa don nao.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ma hoa don</th>
                            <th>Can ho</th>
                            <th>Cu dan</th>
                            <th>Ky</th>
                            <th>Han thanh toan</th>
                            <th>Tong tien</th>
                            <th>Da tra</th>
                            <th>Trang thai</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model.Invoices)
                        {
                            <tr>
                                <td>@invoice.InvoiceCode</td>
                                <td>@invoice.ApartmentCode</td>
                                <td>@invoice.ResidentName</td>
                                <td>@invoice.BillingMonth/@invoice.BillingYear</td>
                                <td>@invoice.DueDate.ToString("dd/MM/yyyy")</td>
                                <td>@invoice.TotalAmount.ToString("#,##0")</td>
                                <td>@invoice.PaidAmount.ToString("#,##0")</td>
                                <td>@invoice.Status</td>
                                <td>
                                    <div class="admin-actions">
                                        <a asp-action="Details" asp-route-id="@invoice.Id" class="btn-ams btn-ams-outline">
                                            <i class="bi bi-eye"></i> Chi tiet
                                        </a>
                                        <a asp-controller="Payments" asp-action="Create" asp-route-invoiceId="@invoice.Id" class="btn-ams btn-ams-outline">
                                            <i class="bi bi-credit-card"></i> Thanh toan
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
