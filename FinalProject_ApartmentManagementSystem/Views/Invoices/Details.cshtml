@model FinalProject_ApartmentManagementSystem.ViewModels.InvoiceDetailsViewModel
@{
    ViewData["Title"] = "Chi tiet hoa don";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canPay = Model.Status != "Paid";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Chi tiet hoa don</div>
            <div class="admin-subtitle">Thong tin chi tiet va lich su thanh toan.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
            @if (canPay)
            {
                <a asp-controller="Payments" asp-action="Create" asp-route-invoiceId="@Model.Id" class="btn-ams btn-ams-primary">
                    <i class="bi bi-credit-card"></i> Thanh toan
                </a>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-receipt"></i>
                Thong tin hoa don
            </div>
        </div>
        <div class="card-body">
            <div class="form-grid">
                <div>
                    <label class="form-label">Ma hoa don</label>
                    <div>@Model.InvoiceCode</div>
                </div>
                <div>
                    <label class="form-label">Can ho</label>
                    <div>@Model.ApartmentCode</div>
                </div>
                <div>
                    <label class="form-label">Cu dan</label>
                    <div>@Model.ResidentName</div>
                </div>
                <div>
                    <label class="form-label">Ky</label>
                    <div>@Model.BillingMonth/@Model.BillingYear</div>
                </div>
                <div>
                    <label class="form-label">Ngay phat hanh</label>
                    <div>@Model.IssueDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div>
                    <label class="form-label">Han thanh toan</label>
                    <div>@Model.DueDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div>
                    <label class="form-label">Tong tien</label>
                    <div>@Model.TotalAmount.ToString("#,##0")</div>
                </div>
                <div>
                    <label class="form-label">Da thanh toan</label>
                    <div>@Model.PaidAmount.ToString("#,##0")</div>
                </div>
                <div>
                    <label class="form-label">Trang thai</label>
                    <div>@Model.Status</div>
                </div>
                <div style="grid-column:1 / -1;">
                    <label class="form-label">Ghi chu</label>
                    <div>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top:20px;">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-list-check"></i>
                Chi tiet phi
            </div>
        </div>
        <div class="card-body">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Loai phi</th>
                        <th>Don vi</th>
                        <th>So luong</th>
                        <th>Don gia</th>
                        <th>Thanh tien</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@item.FeeName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Unit) ? "-" : item.Unit)</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("#,##0")</td>
                            <td>@item.Amount.ToString("#,##0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card" style="margin-top:20px;">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-credit-card"></i>
                Lich su thanh toan
            </div>
        </div>
        <div class="card-body">
            @if (Model.Payments.Count == 0)
            {
                <div class="admin-subtitle">Chua co thanh toan nao.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ngay thanh toan</th>
                            <th>So tien</th>
                            <th>Phuong thuc</th>
                            <th>Ma tham chieu</th>
                            <th>Nguoi ghi nhan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Payments)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.Amount.ToString("#,##0")</td>
                                <td>@payment.PaymentMethod</td>
                                <td>@(string.IsNullOrWhiteSpace(payment.ReferenceNumber) ? "-" : payment.ReferenceNumber)</td>
                                <td>@(string.IsNullOrWhiteSpace(payment.ReceivedByName) ? "-" : payment.ReceivedByName)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
