@model FinalProject_ApartmentManagementSystem.ViewModels.PaymentIndexViewModel
@{
    ViewData["Title"] = "Thanh toan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Lich su thanh toan</div>
            <div class="admin-subtitle">Tong hop cac giao dich thanh toan.</div>
        </div>
        <div class="admin-actions">
            <a asp-controller="Invoices" asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-receipt"></i> Xem hoa don
            </a>
        </div>
    </div>

    @if (TempData["PaymentSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-ams">@success</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-credit-card"></i>
                Danh sach thanh toan
            </div>
        </div>
        <div class="card-body">
            @if (Model.Payments.Count == 0)
            {
                <div class="admin-subtitle">Chua co thanh toan nao.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ma hoa don</th>
                            <th>Can ho</th>
                            <th>Cu dan</th>
                            <th>So tien</th>
                            <th>Ngay thanh toan</th>
                            <th>Phuong thuc</th>
                            <th>Ma tham chieu</th>
                            <th>Nguoi ghi nhan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Payments)
                        {
                            <tr>
                                <td>@payment.InvoiceCode</td>
                                <td>@payment.ApartmentCode</td>
                                <td>@payment.ResidentName</td>
                                <td>@payment.Amount.ToString("#,##0")</td>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.PaymentMethod</td>
                                <td>@(string.IsNullOrWhiteSpace(payment.ReferenceNumber) ? "-" : payment.ReferenceNumber)</td>
                                <td>@(string.IsNullOrWhiteSpace(payment.ReceivedByName) ? "-" : payment.ReceivedByName)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
