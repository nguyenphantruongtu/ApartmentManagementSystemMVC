@model FinalProject_ApartmentManagementSystem.ViewModels.PaymentCreateViewModel
@{
    ViewData["Title"] = "Thanh toan hoa don";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var remaining = Math.Max(0, Model.TotalAmount - Model.PaidAmount);
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Thanh toan hoa don</div>
            <div class="admin-subtitle">Nhap thong tin thanh toan cho hoa don.</div>
        </div>
        <div class="admin-actions">
            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-receipt"></i>
                Thong tin hoa don
            </div>
        </div>
        <div class="card-body">
            <div class="form-grid">
                <div>
                    <label class="form-label">Ma hoa don</label>
                    <div>@Model.InvoiceCode</div>
                </div>
                <div>
                    <label class="form-label">Can ho</label>
                    <div>@Model.ApartmentCode</div>
                </div>
                <div>
                    <label class="form-label">Cu dan</label>
                    <div>@Model.ResidentName</div>
                </div>
                <div>
                    <label class="form-label">Tong tien</label>
                    <div>@Model.TotalAmount.ToString("#,##0")</div>
                </div>
                <div>
                    <label class="form-label">Da thanh toan</label>
                    <div>@Model.PaidAmount.ToString("#,##0")</div>
                </div>
                <div>
                    <label class="form-label">Con lai</label>
                    <div>@remaining.ToString("#,##0")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top:20px;">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-credit-card"></i>
                Thong tin thanh toan
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div style="grid-column:1 / -1;">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
                <input type="hidden" asp-for="InvoiceId" />
                <div>
                    <label class="form-label">So tien thanh toan</label>
                    <input asp-for="Amount" class="form-input" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ngay thanh toan</label>
                    <input asp-for="PaymentDate" class="form-input" type="date" />
                    <span asp-validation-for="PaymentDate" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Phuong thuc</label>
                    <select asp-for="PaymentMethod" class="form-input">
                        <option value="">-- Chon --</option>
                        @foreach (var method in Model.PaymentMethodOptions)
                        {
                            <option value="@method">@method</option>
                        }
                    </select>
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ma tham chieu</label>
                    <input asp-for="ReferenceNumber" class="form-input" />
                    <span asp-validation-for="ReferenceNumber" class="text-danger"></span>
                </div>
                <div style="grid-column:1 / -1;">
                    <label class="form-label">Ghi chu</label>
                    <input asp-for="Note" class="form-input" />
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>
                <div class="admin-actions" style="grid-column:1 / -1;">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Ghi nhan
                    </button>
                    <a asp-controller="Invoices" asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
