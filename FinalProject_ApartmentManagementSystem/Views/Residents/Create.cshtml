@model FinalProject_ApartmentManagementSystem.ViewModels.ResidentFormViewModel
@{
    ViewData["Title"] = "Tao cu dan";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hasUserOptions = Model.UserOptions.Count > 0;
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Tao cu dan moi</div>
            <div class="admin-subtitle">Them thong tin cu dan moi cho he thong.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-people"></i>
                Thong tin cu dan
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Tai khoan</label>
                    <select asp-for="UserId" class="form-input" disabled="@(hasUserOptions ? false : true)"")>
                        <option value="">-- Chon tai khoan --</option>
                        @foreach (var user in Model.UserOptions)
                        {
                            <option value="@user.UserId">@user.DisplayName (@user.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                    @if (!hasUserOptions)
                    {
                        <div class="admin-subtitle">Khong con tai khoan nao chua gan cu dan.</div>
                    }
                </div>
                <div>
                    <label class="form-label">Ho ten</label>
                    <input asp-for="FullName" class="form-input" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ngay sinh</label>
                    <input asp-for="DateOfBirth" class="form-input" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Gioi tinh</label>
                    <input asp-for="Gender" class="form-input" />
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">CCCD</label>
                    <input asp-for="CitizenId" class="form-input" />
                    <span asp-validation-for="CitizenId" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Dien thoai</label>
                    <input asp-for="Phone" class="form-input" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Lien he khan cap</label>
                    <input asp-for="EmergencyContact" class="form-input" />
                    <span asp-validation-for="EmergencyContact" class="text-danger"></span>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary" @(hasUserOptions ? "" : "disabled")>
                        <i class="bi bi-check-circle"></i> Luu
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
