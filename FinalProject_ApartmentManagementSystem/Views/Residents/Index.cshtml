@model FinalProject_ApartmentManagementSystem.ViewModels.ResidentsIndexViewModel
@{
    ViewData["Title"] = "Quan ly cu dan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Quan ly cu dan</div>
            <div class="admin-subtitle">Danh sach va thao tac CRUD cu dan.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Create" class="btn-ams btn-ams-primary">
                <i class="bi bi-plus-circle"></i> Tao cu dan
            </a>
        </div>
    </div>

    @if (TempData["ResidentSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-ams">@success</div>
    }
    @if (TempData["ResidentError"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="alert-ams">@error</div>
    }

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-people"></i>
                Danh sach cu dan
            </div>
        </div>
        <div class="card-body">
            @if (Model.Residents.Count == 0)
            {
                <div class="admin-subtitle">Chua co cu dan nao. Hay tao cu dan dau tien.</div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Ho ten</th>
                            <th>User ID</th>
                            <th>Ngay sinh</th>
                            <th>Gioi tinh</th>
                            <th>CCCD</th>
                            <th>Dien thoai</th>
                            <th>Email</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var resident in Model.Residents)
                        {
                            <tr>
                                <td>@resident.FullName</td>
                                <td>@resident.UserId</td>
                                <td>@(resident.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(resident.Gender) ? "-" : resident.Gender)</td>
                                <td>@(string.IsNullOrWhiteSpace(resident.CitizenId) ? "-" : resident.CitizenId)</td>
                                <td>@(string.IsNullOrWhiteSpace(resident.Phone) ? "-" : resident.Phone)</td>
                                <td>@(string.IsNullOrWhiteSpace(resident.Email) ? "-" : resident.Email)</td>
                                <td>
                                    <div class="admin-actions">
                                        <a asp-action="Details" asp-route-id="@resident.Id" class="btn-ams btn-ams-outline">
                                            <i class="bi bi-eye"></i> Chi tiet
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@resident.Id" class="btn-ams btn-ams-outline">
                                            <i class="bi bi-pencil"></i> Sua
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@resident.Id" method="post" onsubmit="return confirm('Xoa cu dan nay?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-ams btn-ams-danger">
                                                <i class="bi bi-trash"></i> Xoa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
