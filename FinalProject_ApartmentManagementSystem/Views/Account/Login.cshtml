@model FinalProject_ApartmentManagementSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Đăng nhập — AMS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
          rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --blue      : #1044A3;
            --blue-dark : #0A2F7A;
            --blue-light: #2563EB;
            --blue-btn  : #1A56DB;
            --red       : #D32F2F;
            --text-main : #1A2340;
            --text-sub  : #6B7A99;
            --border    : #DDE3EF;
        }

        html, body {
            height      : 100%;
            font-family : 'Be Vietnam Pro', sans-serif;
            font-size   : 15px;
            color       : var(--text-main);
        }

        a { text-decoration: none; color: inherit; }

        .page {
            min-height       : 100vh;
            display          : flex;
            flex-direction   : column;
            position         : relative;
            background-image: url('/Asset/auth_background.png');
            background-size  : cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .page::before {
            content    : '';
            position   : absolute;
            inset      : 0;
            background : linear-gradient(
                to right,
                rgba(10, 20, 50, .45) 0%,
                rgba(10, 20, 50, .10) 55%,
                rgba(10, 20, 50, .02) 100%
            );
            pointer-events: none;
        }

        .topbar {
            position        : relative;
            z-index         : 10;
            display         : flex;
            align-items     : center;
            justify-content : space-between;
            padding         : 22px 48px;
        }

        .logo {
            display     : flex;
            align-items : center;
            gap         : 10px;
        }
        .logo-icon {
            width           : 40px;
            height          : 40px;
            border-radius   : 10px;
            background      : rgba(255,255,255,.15);
            backdrop-filter : blur(6px);
            border          : 1px solid rgba(255,255,255,.25);
            display         : flex;
            align-items     : center;
            justify-content : center;
            font-size       : 1.15rem;
            color           : #fff;
        }
        .logo-name {
            font-size   : 1.1rem;
            font-weight : 700;
            color       : #fff;
            letter-spacing: .01em;
        }
        .logo-name span {
            font-weight : 300;
            opacity     : .75;
        }

        .topbar-hotline {
            font-size   : .82rem;
            color: rgba(255, 0, 0, 1);
            font-weight : 500;
            display     : flex;
            align-items : center;
            gap         : 1x;
            font-weight : bold;
        }
        .topbar-hotline i { font-size: .95rem; }

        .main {
            flex            : 1;
            display         : flex;
            align-items     : center;
            justify-content : flex-end;
            padding         : 0 48px;
            position        : relative;
            z-index         : 10;
        }

        .card {
            background    : rgba(255, 255, 255, .96);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius : 16px;
            padding       : 48px 44px 40px;
            width         : 420px;
            box-shadow    : 0 24px 64px rgba(10, 20, 60, .22),
                            0 4px 16px  rgba(10, 20, 60, .10);
        }

        .card-title {
            font-size    : 1.65rem;
            font-weight  : 700;
            color        : var(--text-main);
            line-height  : 1.3;
            margin-bottom: 32px;
        }
        .card-title span {
            color           : var(--blue-light);
            font-style      : italic;
            font-weight     : 700;
            background      : linear-gradient(90deg, var(--blue), var(--blue-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip : text;
        }

        .error-box {
            display       : flex;
            align-items   : flex-start;
            gap           : 8px;
            background    : #FFF5F5;
            border        : 1px solid #FECACA;
            border-left   : 3px solid var(--red);
            border-radius : 8px;
            padding       : 11px 14px;
            font-size     : .8rem;
            color         : #B91C1C;
            margin-bottom : 20px;
            line-height   : 1.5;
        }
        .error-box i { flex-shrink: 0; margin-top: 1px; }

        .field { margin-bottom: 28px; position: relative; }

        .field input {
            width           : 100%;
            background      : transparent;
            border          : none;
            border-bottom   : 1.5px solid var(--border);
            border-radius   : 0;
            padding         : 10px 36px 10px 0;
            font-size       : .95rem;
            font-family     : 'Be Vietnam Pro', sans-serif;
            color           : var(--text-main);
            outline         : none;
            transition      : border-color .2s;
        }
        .field input::placeholder { color: var(--text-sub); font-weight: 400; }

        .field::after {
            content    : '';
            position   : absolute;
            bottom     : 0; left: 0;
            width      : 0;
            height     : 2px;
            background : var(--blue-light);
            transition : width .25s ease;
        }
        .field:focus-within::after { width: 100%; }
        .field:focus-within input  { border-bottom-color: transparent; }

        .field-icon {
            position   : absolute;
            right      : 0;
            bottom     : 10px;
            color      : var(--text-sub);
            font-size  : .95rem;
            cursor     : pointer;
            transition : color .15s;
            background : none;
            border     : none;
            padding    : 0;
            line-height: 1;
        }
        .field-icon:hover { color: var(--blue-light); }

        .field-error {
            display    : block;
            font-size  : .72rem;
            color      : var(--red);
            margin-top : 4px;
        }

        .form-foot {
            display         : flex;
            align-items     : center;
            justify-content : space-between;
            margin-bottom   : 28px;
        }
        .check-wrap {
            display     : flex;
            align-items : center;
            gap         : 7px;
            cursor      : pointer;
            font-size   : .82rem;
            color       : var(--text-sub);
            user-select : none;
        }
        .check-wrap input[type="checkbox"] {
            width        : 15px; height: 15px;
            accent-color : var(--blue-light);
            cursor       : pointer;
            flex-shrink  : 0;
        }

        .submit-row {
            display         : flex;
            align-items     : center;
            gap             : 14px;
            margin-bottom   : 32px;
        }
        .btn-submit {
            width           : 52px;
            height          : 52px;
            border-radius   : 50%;
            background      : var(--blue-btn);
            border          : none;
            color           : #fff;
            font-size       : 1.25rem;
            display         : flex;
            align-items     : center;
            justify-content : center;
            cursor          : pointer;
            flex-shrink     : 0;
            box-shadow      : 0 4px 16px rgba(26, 86, 219, .40);
            transition      : background .2s, transform .15s, box-shadow .2s;
        }
        .btn-submit:hover {
            background : var(--blue);
            transform  : scale(1.06);
            box-shadow : 0 6px 20px rgba(26, 86, 219, .55);
        }
        .btn-submit:active  { transform: scale(.97); }
        .btn-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }

        @@keyframes spin { to { transform: rotate(360deg); } }
        .spinner {
            width        : 20px; height: 20px;
            border       : 2.5px solid rgba(255,255,255,.4);
            border-top   : 2.5px solid #fff;
            border-radius: 50%;
            animation    : spin .7s linear infinite;
        }

        .card-links {
            display         : flex;
            justify-content : space-between;
            padding-top     : 18px;
            border-top      : 1px solid var(--border);
        }
        .card-links a {
            font-size   : .82rem;
            color       : var(--text-sub);
            transition  : color .15s;
        }
        .card-links a:hover { color: var(--blue); }

        .footer {
            position        : relative;
            z-index         : 10;
            display         : flex;
            align-items     : flex-end;
            justify-content : space-between;
            padding         : 20px 48px 28px;
        }

        .footer-author {
            font-size   : .85rem;
            font-weight : 700;
            color       : #fff;
            margin-bottom: 4px;
        }
        .footer-links {
            display : flex;
            gap     : 20px;
        }
        .footer-links a {
            font-size   : .78rem;
            color       : rgba(255,255,255,.75);
            transition  : color .15s;
        }
        .footer-links a:hover { color: #fff; }

        .footer-copy {
            font-size : .75rem;
            color     : rgba(255,255,255,.65);
            text-align: right;
        }

        @@media (max-width: 640px) {
            .topbar  { padding: 18px 20px; }
            .main    { padding: 20px; justify-content: center; }
            .card    { width: 100%; padding: 36px 24px 30px; }
            .footer  { padding: 16px 20px 22px; flex-direction: column; gap: 10px; }
            .footer-copy { text-align: left; }
            .topbar-hotline { display: none; }
        }
    </style>
</head>
<body>
<div class="page">
    <header class="topbar">
        <div class="logo">
            <div class="logo-icon">
                <i class="bi bi-buildings-fill"></i>
            </div>
            <div class="logo-name">
                AMS <span>Building</span>
            </div>
        </div>

        <div class="topbar-hotline">
            <i class="bi bi-telephone"></i>
            Hotline hỗ trợ: <strong>0943 802 686</strong>
        </div>
    </header>

    <main class="main">
        <div class="card">
            <h1 class="card-title">
                Chào mừng Quý khách<br>
                đến <span>Apartment Management System</span>
            </h1>

            @if (!ViewData.ModelState.IsValid
                 && ViewData.ModelState.ContainsKey(string.Empty)
                 && ViewData.ModelState[string.Empty]!.Errors.Any())
            {
                <div class="error-box">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div>
                        @foreach (var err in ViewData.ModelState[string.Empty]!.Errors)
                        {
                            <div>@err.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post" novalidate id="loginForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl">

                <div class="field">
                    <input asp-for="Username"
                           placeholder="Tên đăng nhập"
                           autocomplete="username"
                           autofocus
                           spellcheck="false">
                    <i class="bi bi-person field-icon" style="cursor:default; pointer-events:none;"></i>
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>

                <div class="field">
                    <input asp-for="Password"
                           placeholder="Mật khẩu"
                           id="pwdInput"
                           autocomplete="current-password">
                    <button type="button" class="field-icon" id="eyeBtn"
                            onclick="togglePwd()" title="Hiện/ẩn mật khẩu"
                            tabindex="-1">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="form-foot">
                    <label class="check-wrap">
                        <input asp-for="RememberMe" type="checkbox">
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <div class="submit-row">
                    <div style="flex:1;"></div>
                    <button type="submit" class="btn-submit" id="btnSubmit" title="Đăng nhập">
                        <i class="bi bi-arrow-right" id="btnIcon"></i>
                    </button>
                </div>

                <div class="card-links">
                    <a asp-action="ForgotPassword" asp-controller="Account">
                        Quên tên đăng nhập / Mật khẩu
                    </a>
                    <a asp-action="Register" asp-controller="Account">
                        Đăng ký
                    </a>
                </div>
            </form>
        </div>
    </main>

    <footer class="footer">
        <div class="footer-left">
            <div class="footer-author">S-TECH Building Management</div>
            <div class="footer-links">
                <a href="#">Về chúng tôi</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Điều khoản sử dụng</a>
            </div>
        </div>
        <div class="footer-copy">
            © Bản quyền thuộc về S-TECH Building Management System
        </div>
    </footer>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script>
    function togglePwd() {
        const input = document.getElementById('pwdInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    document.getElementById('loginForm').addEventListener('submit', function () {
        const btn = document.getElementById('btnSubmit');
        const icon = document.getElementById('btnIcon');

        if (!this.checkValidity()) return;

        btn.disabled = true;
        icon.outerHTML = '<div class="spinner"></div>';
    });
</script>

</body>
</html>
