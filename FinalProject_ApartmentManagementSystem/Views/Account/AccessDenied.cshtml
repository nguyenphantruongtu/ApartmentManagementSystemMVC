@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Không có quyền truy cập</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap"
          rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: 'Be Vietnam Pro', sans-serif;
            background: url('/Asset/auth_background.png') center / cover no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* Overlay */
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(10, 20, 50, .55);
        }

        /* Modal */
        .access-modal {
            position: relative;
            z-index: 10;
            width: 420px;
            background: rgba(255, 255, 255, .96);
            border-radius: 16px;
            padding: 40px 36px 34px;
            text-align: center;
            box-shadow: 0 24px 64px rgba(10, 20, 60, .25), 0 4px 16px rgba(10, 20, 60, .12);
            animation: scaleIn .25s ease;
        }


        .icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 18px;
            border-radius: 50%;
            background: #FFF5F5;
            color: #D32F2F;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 700;
        }

        h1 {
            font-size: 1.45rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #1A2340;
        }

        p {
            font-size: .9rem;
            color: #6B7A99;
            line-height: 1.5;
            margin-bottom: 28px;
        }

        .actions {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
        }

        .btn-primary {
            background: #1A56DB;
            color: #fff;
        }

        .btn-primary:hover {
            background: #1044A3;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #DDE3EF;
            color: #1A2340;
        }

        .btn-outline:hover {
            background: #F4F6FB;
        }
    </style>
</head>

<body>

    <div class="access-modal">
        <div class="icon">!</div>

        <h1>Không có quyền truy cập</h1>

        <p>
            Tài khoản của bạn không có quyền thực hiện thao tác này.<br />
            Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là nhầm lẫn.
        </p>

        <div class="actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                Trang chủ
            </a>
            <button class="btn btn-outline" onclick="history.back()">
                Quay lại
            </button>
        </div>
    </div>

</body>
</html>