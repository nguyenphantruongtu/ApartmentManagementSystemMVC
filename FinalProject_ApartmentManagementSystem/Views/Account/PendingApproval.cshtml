@{
    ViewData["Title"] = "Chờ phê duyệt";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Chờ phê duyệt — AMS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
          rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --blue: #1044A3;
            --blue-dark: #0A2F7A;
            --blue-light: #2563EB;
            --blue-btn: #1A56DB;
            --text-main: #1A2340;
            --text-sub: #6B7A99;
            --border: #DDE3EF;
        }

        html, body {
            height: 100%;
            font-family: 'Be Vietnam Pro', sans-serif;
            font-size: 15px;
            color: var(--text-main);
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ── Copy nguyên từ Login ── */
        .page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            background-image: url('/Asset/auth_background.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

            .page::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient( to right, rgba(10, 20, 50, .45) 0%, rgba(10, 20, 50, .10) 55%, rgba(10, 20, 50, .02) 100% );
                pointer-events: none;
            }

        .topbar {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 22px 48px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255,255,255,.15);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            color: #fff;
        }

        .logo-name {
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: .01em;
        }

            .logo-name span {
                font-weight: 300;
                opacity: .75;
            }

        .topbar-hotline {
            font-size: .82rem;
            color: rgba(255, 0, 0, 1);
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 1px;
        }

            .topbar-hotline i {
                font-size: .95rem;
            }

        /* ── Chỉ thay đổi: center thay vì flex-end ── */
        .main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 48px;
            position: relative;
            z-index: 10;
        }

        /* ── Card: giữ nguyên từ Login ── */
        .card {
            background: rgba(255, 255, 255, .96);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 16px;
            padding: 48px 44px 40px;
            width: 420px;
            box-shadow: 0 24px 64px rgba(10, 20, 60, .22), 0 4px 16px rgba(10, 20, 60, .10);
            text-align: center;
        }

        /* ── Icon đồng hồ cát ── */
        .status-icon {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: #ECFDF5;
            border: 2px solid #A7F3D0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 1.75rem;
            color: #059669;
            animation: pulse 2.4s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(5, 150, 105, .25);
            }

            50% {
                box-shadow: 0 0 0 10px rgba(5, 150, 105, 0);
            }
        }

        /* ── Title: cùng font/size với Login ── */
        .card-title {
            font-size: 1.65rem;
            font-weight: 700;
            color: var(--text-main);
            line-height: 1.3;
            margin-bottom: 16px;
        }

            .card-title span {
                font-style: italic;
                font-weight: 700;
                background: linear-gradient(90deg, var(--blue), var(--blue-light));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        /* ── Dòng thông báo chính ── */
        .card-desc {
            font-size: .88rem;
            color: var(--text-sub);
            line-height: 1.75;
            margin-bottom: 32px;
        }

            .card-desc strong {
                color: var(--text-main);
                font-weight: 600;
            }

        /* ── Divider: copy từ border-top card-links trong Login ── */
        .card-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 0 0 20px;
        }

        /* ── Nút quay về: dùng lại màu btn-submit của Login ── */
        .btn-back {
            width: 100%;
            height: 46px;
            border-radius: 10px;
            background: var(--blue-btn);
            border: none;
            color: #fff;
            font-size: .9rem;
            font-weight: 600;
            font-family: 'Be Vietnam Pro', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 4px 16px rgba(26, 86, 219, .40);
            transition: background .2s, transform .15s, box-shadow .2s;
            margin-bottom: 16px;
        }

            .btn-back:hover {
                background: var(--blue);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(26, 86, 219, .55);
                color: #fff;
            }

            .btn-back:active {
                transform: translateY(0);
            }

        /* ── Note: copy từ card-links style Login ── */
        .card-note {
            font-size: .82rem;
            color: var(--text-sub);
        }

            .card-note a {
                color: var(--blue-light);
                font-weight: 500;
                transition: color .15s;
            }

                .card-note a:hover {
                    color: var(--blue);
                }

        /* ── Footer: copy nguyên từ Login ── */
        .footer {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            padding: 20px 48px 28px;
        }

        .footer-author {
            font-size: .85rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 4px;
        }

        .footer-links {
            display: flex;
            gap: 20px;
        }

            .footer-links a {
                font-size: .78rem;
                color: rgba(255,255,255,.75);
                transition: color .15s;
            }

                .footer-links a:hover {
                    color: #fff;
                }

        .footer-copy {
            font-size: .75rem;
            color: rgba(255,255,255,.65);
            text-align: right;
        }

        @@media (max-width: 640px) {
            .topbar {
                padding: 18px 20px;
            }

            .main {
                padding: 20px;
            }

            .card {
                width: 100%;
                padding: 36px 24px 30px;
            }

            .footer {
                padding: 16px 20px 22px;
                flex-direction: column;
                gap: 10px;
            }

            .footer-copy {
                text-align: left;
            }

            .topbar-hotline {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="page">

        @* ── TOPBAR — giữ nguyên từ Login ── *@
        <header class="topbar">
            <div class="logo">
                <div class="logo-icon">
                    <i class="bi bi-buildings-fill"></i>
                </div>
                <div class="logo-name">
                    AMS <span>Building</span>
                </div>
            </div>
            <div class="topbar-hotline">
                <i class="bi bi-telephone"></i>
                Hotline hỗ trợ: <strong>0943 802 686</strong>
            </div>
        </header>

        @* ── MAIN ── *@
        <main class="main">
            <div class="card">

                @* Icon trạng thái *@
                <div class="status-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>

                @* Tiêu đề *@
                <h1 class="card-title">
                    Đăng ký <span>thành công!</span>
                </h1>

                @* Thông báo chính *@
                <p class="card-desc">
                    Tài khoản của bạn đã được đăng ký thành công.<br>
                    <strong>Vui lòng chờ Admin phê duyệt</strong> trước khi đăng nhập.<br>
                    Bạn sẽ nhận thông báo qua email khi tài khoản được kích hoạt.
                </p>

                <hr class="card-divider">

                @* Nút quay về Login *@
                <a asp-controller="Account" asp-action="Login" class="btn-back">
                    <i class="bi bi-arrow-left"></i>
                    Quay về trang đăng nhập
                </a>

                @* Hỗ trợ *@
                <p class="card-note">
                    Cần hỗ trợ? Liên hệ
                    <a href="tel:0943802686">0943 802 686</a>
                    hoặc
                    <a href="mailto:support@ams.vn">support@ams.vn</a>
                </p>

            </div>
        </main>

        @* ── FOOTER — giữ nguyên từ Login ── *@
        <footer class="footer">
            <div class="footer-left">
                <div class="footer-author">S-TECH Building Management</div>
                <div class="footer-links">
                    <a href="#">Về chúng tôi</a>
                    <a href="#">Chính sách bảo mật</a>
                    <a href="#">Điều khoản sử dụng</a>
                </div>
            </div>
            <div class="footer-copy">
                © Bản quyền thuộc về S-TECH Building Management System
            </div>
        </footer>

    </div>
</body>
</html>
