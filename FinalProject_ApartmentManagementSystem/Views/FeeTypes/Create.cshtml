@model FinalProject_ApartmentManagementSystem.ViewModels.FeeTypeFormViewModel
@{
    ViewData["Title"] = "Tao loai phi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Tao loai phi moi</div>
            <div class="admin-subtitle">Nhap thong tin loai phi can quan ly.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-receipt"></i>
                Thong tin loai phi
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Ma phi</label>
                    <input asp-for="FeeCode" class="form-input" />
                    <span asp-validation-for="FeeCode" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Ten phi</label>
                    <input asp-for="FeeName" class="form-input" />
                    <span asp-validation-for="FeeName" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Don vi</label>
                    <input asp-for="Unit" class="form-input" />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Don gia</label>
                    <input asp-for="UnitPrice" class="form-input" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Mo ta</label>
                    <input asp-for="Description" class="form-input" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <input asp-for="IsActive" type="checkbox" />
                    <label class="form-label" style="margin-bottom:0;">Dang hoat dong</label>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Luu
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
