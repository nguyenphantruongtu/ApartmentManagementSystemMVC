@model FinalProject_ApartmentManagementSystem.ViewModels.IssueDetailsViewModel
@{
    ViewData["Title"] = "Chi tiet su co";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var imageUrls = string.IsNullOrWhiteSpace(Model.ImageUrls)
        ? Array.Empty<string>()
        : Model.ImageUrls.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Chi tiet su co</div>
            <div class="admin-subtitle">Thong tin bao cao va xu ly su co.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-tools"></i>
                Thong tin su co
            </div>
        </div>
        <div class="card-body">
            <div class="form-grid">
                <div>
                    <label class="form-label">Ma su co</label>
                    <div class="form-input">@Model.IssueCode</div>
                </div>
                <div>
                    <label class="form-label">Trang thai</label>
                    <div class="form-input">@Model.Status</div>
                </div>
                <div>
                    <label class="form-label">Tieu de</label>
                    <div class="form-input">@Model.Title</div>
                </div>
                <div>
                    <label class="form-label">Danh muc</label>
                    <div class="form-input">@Model.CategoryName</div>
                </div>
                <div>
                    <label class="form-label">Can ho</label>
                    <div class="form-input">@Model.ApartmentCode</div>
                </div>
                <div>
                    <label class="form-label">Toa nha</label>
                    <div class="form-input">@(!string.IsNullOrWhiteSpace(Model.BuildingName) ? Model.BuildingName : "-")</div>
                </div>
                <div>
                    <label class="form-label">Uu tien</label>
                    <div class="form-input">@Model.Priority</div>
                </div>
                <div>
                    <label class="form-label">Nguoi bao</label>
                    <div class="form-input">@Model.ReportedByName</div>
                </div>
                <div>
                    <label class="form-label">Nguoi xu ly</label>
                    <div class="form-input">@(!string.IsNullOrWhiteSpace(Model.AssignedToName) ? Model.AssignedToName : "-")</div>
                </div>
                <div>
                    <label class="form-label">Ngay tao</label>
                    <div class="form-input">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div>
                    <label class="form-label">Cap nhat</label>
                    <div class="form-input">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div>
                    <label class="form-label">Ngay hoan thanh</label>
                    <div class="form-input">@((Model.ResolvedDate.HasValue) ? Model.ResolvedDate.Value.ToString("dd/MM/yyyy HH:mm") : "-")</div>
                </div>
                <div>
                    <label class="form-label">Mo ta</label>
                    <div class="form-input">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "-")</div>
                </div>
                <div>
                    <label class="form-label">Ghi chu xu ly</label>
                    <div class="form-input">@(!string.IsNullOrWhiteSpace(Model.ResolutionNotes) ? Model.ResolutionNotes : "-")</div>
                </div>
                <div>
                    <label class="form-label">Hinh anh</label>
                    @if (imageUrls.Length == 0)
                    {
                        <div class="form-input">-</div>
                    }
                    else
                    {
                        <div class="form-input">
                            <ul style="margin:0; padding-left:1rem;">
                                @foreach (var url in imageUrls)
                                {
                                    <li><a href="@url" target="_blank">@url</a></li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
