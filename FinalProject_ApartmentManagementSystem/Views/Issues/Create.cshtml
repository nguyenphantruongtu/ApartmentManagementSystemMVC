@model FinalProject_ApartmentManagementSystem.ViewModels.IssueCreateViewModel
@{
    ViewData["Title"] = "Bao su co";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-roles.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <div class="admin-title">Bao su co</div>
            <div class="admin-subtitle">Gui yeu cau ho tro va mo ta su co.</div>
        </div>
        <div class="admin-actions">
            <a asp-action="Index" class="btn-ams btn-ams-outline">
                <i class="bi bi-arrow-left"></i> Quay lai
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="bi bi-tools"></i>
                Thong tin su co
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Danh muc</label>
                    <select asp-for="CategoryId" class="form-input">
                        <option value="">-- Chon danh muc --</option>
                        @foreach (var category in Model.CategoryOptions)
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Tieu de</label>
                    <input asp-for="Title" class="form-input" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Mo ta chi tiet</label>
                    <textarea asp-for="Description" class="form-input" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Hinh anh (URL, cach nhau boi dau phay)</label>
                    <textarea asp-for="ImageUrls" class="form-input" rows="3"></textarea>
                    <span asp-validation-for="ImageUrls" class="text-danger"></span>
                </div>
                <div class="admin-actions">
                    <button type="submit" class="btn-ams btn-ams-primary">
                        <i class="bi bi-check-circle"></i> Gui bao cao
                    </button>
                    <a asp-action="Index" class="btn-ams btn-ams-outline">Huy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
